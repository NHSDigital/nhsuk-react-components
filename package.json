{
  "name": "nhsuk-react-components",
  "version": "6.0.0-beta.0",
  "author": {
    "name": "NHS England"
  },
  "files": [
    "dist",
    "lib"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "cleanup": "rm -rf dist/ lib/ >/dev/null 2>&1 || true",
    "build": "yarn cleanup && rollup -c",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage",
    "lint": "eslint 'src/**/*.{js,ts,tsx}' 'stories/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,ts,tsx}' 'stories/**/*.{js,ts,tsx}' --fix",
    "lint:ci": "eslint 'src/**/*.{js,ts,tsx}' 'stories/**/*.{js,ts,tsx}'",
    "prepublishOnly": "yarn lint:ci && yarn test:ci && yarn storybook --smoke-test"
  },
  "peerDependencies": {
    "nhsuk-frontend": ">=10.0.0 <11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.36.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@storybook/addon-docs": "9.1.3",
    "@storybook/addon-links": "^9.1.3",
    "@storybook/react-vite": "^9.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/babel__preset-env": "^7",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/lodash": "^4",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19",
    "@types/stylus": "^0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "9.1.3",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.1.2",
    "nhsuk-frontend": "^10.0.0",
    "outdent": "^0.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rollup": "^4.13.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "sass-embedded": "^1.93.2",
    "storybook": "^9.1.3",
    "stylus": "^0.64.0",
    "ts-jest": "^29.4.4",
    "tslib": "^2.8.1",
    "typescript": "5.3.3",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "license": "MIT",
  "packageManager": "yarn@4.1.1",
  "dependencies": {
    "chalk": "^5.6.2",
    "classnames": "^2.5.1",
    "i": "^0.3.7",
    "lodash": "^4.17.21",
    "npm": "^11.6.0"
  },
  "typesVersions": {
    "*": {
      "react": [
        "node_modules/react/index.d.ts"
      ]
    }
  }
}
